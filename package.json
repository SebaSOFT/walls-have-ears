{
  "name": "walls-have-ears",
  "version": "3.14.2",
  "description": "A simple-as-possible module to muffle sounds that are behind a wall for a player.",
  "source": [
    "src/index.ts",
    "!src/**/*.test.ts"
  ],
  "main": "dist/main.js",
  "types": "dist/types.d.ts",
  "type": "module",
  "scripts": {
    "build": "parcel build",
    "build:analyze": "parcel build --reporter @parcel/reporter-bundle-analyzer",
    "dev": "parcel watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "lint": "eslint --config eslint.config.js src/**/*.ts",
    "lint:fix": "eslint --config eslint.config.js src/**/*.ts --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://SebaSOFT@github.com/SebaSOFT/walls-have-ears.git"
  },
  "keywords": [
    "foundryvtt",
    "foundry",
    "module",
    "audio"
  ],
  "author": "SebaSOFT (sebasoft@gmail.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SebaSOFT/walls-have-ears/issues"
  },
  "homepage": "https://github.com/SebaSOFT/walls-have-ears#readme",
  "devDependencies": {
    "@parcel/packager-ts": "2.16.4",
    "@parcel/reporter-bundle-analyzer": "^2.16.4",
    "@parcel/transformer-typescript-tsc": "^2.16.4",
    "@parcel/transformer-typescript-types": "2.16.4",
    "@types/jest": "^30.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "fvtt-types": "npm:@league-of-foundry-developers/foundry-vtt-types@latest",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "parcel": "^2.16.4",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "packageManager": "yarn@4.9.2"
}
